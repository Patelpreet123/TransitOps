generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  FLEET_MANAGER
  DRIVER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  ON_LEAVE
}

enum TripStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum FuelStatus {
  RECORDED
  VOIDED
}

enum ExpenseStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Driver {
  id                String       @id @default(cuid())
  fullName          String
  email             String       @unique
  phone             String
  licenseNumber     String       @unique
  licenseExpiryDate DateTime
  status            DriverStatus @default(AVAILABLE)
  assignedVehicle   String?      @unique
  trips             Trip[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model Trip {
  id               String     @id @default(cuid())
  vehiclePlateNumber String
  driverId         String
  source           String
  destination      String
  cargoDescription String
  cargoWeightKg    Float
  distanceKm       Float
  startDate        DateTime
  endDate          DateTime
  status           TripStatus @default(SCHEDULED)
  driver           Driver     @relation(fields: [driverId], references: [id], onDelete: Restrict)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([status])
  @@index([vehiclePlateNumber])
  @@index([driverId])
}

model MaintenanceRecord {
  id                 String            @id @default(cuid())
  vehiclePlateNumber String
  serviceType        String
  scheduledDate      DateTime
  completionDate     DateTime?
  cost               Float
  notes              String?
  status             MaintenanceStatus @default(SCHEDULED)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([vehiclePlateNumber])
  @@index([status])
  @@index([scheduledDate])
}

model FuelRecord {
  id                 String      @id @default(cuid())
  vehiclePlateNumber String
  tripId             String?
  fuelType           String
  liters             Float
  unitPrice          Float
  totalCost          Float
  refueledAt         DateTime
  odometerKm         Float?
  notes              String?
  status             FuelStatus  @default(RECORDED)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([vehiclePlateNumber])
  @@index([tripId])
  @@index([status])
  @@index([refueledAt])
}

model ExpenseRecord {
  id                 String         @id @default(cuid())
  title              String
  category           String
  amount             Float
  expenseDate        DateTime
  vendor             String?
  paymentMethod      String
  vehiclePlateNumber String?
  tripId             String?
  notes              String?
  status             ExpenseStatus  @default(PENDING)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([category])
  @@index([vehiclePlateNumber])
  @@index([tripId])
  @@index([status])
  @@index([expenseDate])
}
